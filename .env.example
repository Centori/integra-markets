# Copy this to .env and fill in real values before running `npx expo export --platform web`
# or `npx expo start`. These are baked into the client bundle at build time.
#
# All EXPO_PUBLIC_* vars are safe to embed — they're visible in every user's
# browser devtools regardless. Non-EXPO_PUBLIC secrets belong in EAS secrets
# for mobile builds and Vercel env for the Next.js dashboard.
#
# The same values also live in:
#   - eas.json  → production.env  (used for EAS iOS/Android builds)
#   - Vercel    → integra-dashboard project env vars (used for the /api-* routes)

EXPO_PUBLIC_API_URL=https://api.integramarkets.app
EXPO_PUBLIC_SUPABASE_URL=https://zhdcpiopihqwcmicjpca.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<paste your Supabase anon public key>
