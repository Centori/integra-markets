# Copy to .env.local and fill in.

# Same Supabase project as the mobile app.
NEXT_PUBLIC_SUPABASE_URL=https://zhdcpiopihqwcmicjpca.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where the dashboard sends /api/keys requests. Override for local backend.
NEXT_PUBLIC_INTEGRA_API_URL=https://api.integramarkets.app

# Set to 1 once the Apple Services ID is configured in Supabase — shows the
# "Continue with Apple" button on /login.
NEXT_PUBLIC_ENABLE_APPLE_AUTH=
