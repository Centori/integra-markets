{
  "expo": {
    "name": "Integra Markets",
    "slug": "integra",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "description": "Professional financial markets analysis and news aggregation platform with AI-powered sentiment analysis for commodities trading.",
    "keywords": [
      "finance",
      "markets",
      "trading",
      "commodities",
      "news",
      "analysis",
      "AI",
      "sentiment"
    ],
    "category": "finance",
    "privacy": "https://integramarkets.com/privacy",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.centori.integramarkets",
      "buildNumber": "54",
      "deploymentTarget": "13.0",
      "supportsTablet": true,
      "requireFullScreen": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "appStoreUrl": "https://apps.apple.com/app/integra-markets/id123456789",
      "category": "finance",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCalendarsUsageDescription": "This app may use your calendar to schedule market event reminders.",
        "NSCalendarsFullAccessUsageDescription": "This app may use your calendar to schedule market event reminders.",
        "NSCalendarsWriteOnlyAccessUsageDescription": "This app may add market event reminders to your calendar.",
        "NSRemindersUsageDescription": "This app may set reminders for market events you bookmark.",
        "NSRemindersFullAccessUsageDescription": "This app may set reminders for market events you bookmark.",
        "NSCameraUsageDescription": "This app uses the camera to capture financial documents and receipts.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to select financial documents and receipts.",
        "NSFaceIDUsageDescription": "This app uses Face ID for secure authentication.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": false,
          "NSExceptionDomains": {}
        },
        "NSUserNotificationsUsageDescription": "This app sends notifications for market alerts and breaking news.",
        "NSKeychainAccessGroups": [
          "$(AppIdentifierPrefix)com.centori.integramarkets",
          "$(AppIdentifierPrefix)com.centori.integramarkets"
        ],
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "fetch",
          "remote-notification"
        ],
        "UIRequiresFullScreen": false,
        "LSRequiresIPhoneOS": true,
        "UIStatusBarStyle": "UIStatusBarStyleDefault",
        "UNUserNotificationCenter": {
          "UNAuthorizationOptionAlert": true,
          "UNAuthorizationOptionBadge": true,
          "UNAuthorizationOptionSound": true,
          "UNAuthorizationOptionCriticalAlert": false,
          "UNAuthorizationOptionProvidesAppNotificationSettings": true
        }
      },
      "runtimeVersion": "1.0.1",
      "jsEngine": "hermes",
      "appleTeamId": "2ABHLWV763",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.centori.integramarkets",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_FINGERPRINT"
      ],
      "runtimeVersion": "1.0.1"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
